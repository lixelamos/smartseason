# Local: SQLite. Vercel/serverless: use a hosted Postgres (Neon, Supabase, etc.) — file DB is not durable on serverless.
# busy_timeout avoids indefinite waits if another tool holds the SQLite file open.
DATABASE_URL="file:./dev.db?busy_timeout=8000"
JWT_SECRET="replace-with-long-random-string"
PORT=4000
