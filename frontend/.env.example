# Production / preview: full URL of the deployed API (no trailing slash).
# Ignored during `npm run dev` — local always uses /api → Vite proxy → http://localhost:4000
# On Vercel, frontend/vercel.json can proxy /api → backend so this is optional; setting it still works.
# If you skip the proxy, set this in Vercel for Production and Preview (beta deploys).
VITE_API_URL=https://smartseason-m3hv.vercel.app
